# Copy to .env and set values for local development.

# General app settings
APP_ENV=development      # or production
LOG_LEVEL=INFO           # DEBUG, INFO, WARNING, ERROR

# OpenAI API configuration
OPENAI_API_KEY=sk-...            # required
OPENAI_MODEL=gpt-5.2             # default chat/model for prompts
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe  # model used for audio->text

# Optional: path to a real audio/video file used by tests or manual runs.
# Leave commented out unless you need it.
# TEST_AUDIO_PATH=/absolute/path/to/real_audio_or_video.mp4
